# =============================================================================
# Payload CMS — environment template.
# Copy this file to `apps/cms/.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- Core --------------------------------------------------------------------
PAYLOAD_SECRET=change-me

# --- Database ----------------------------------------------------------------
# Local docker-compose.cms.yml example:
#   postgresql://postgres:postgres@localhost:5433/status_cms
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/status_cms

# PAYLOAD_DB_SCHEMA=payload
# PAYLOAD_DB_PUSH=true

# --- URLs --------------------------------------------------------------------
NEXT_PUBLIC_SERVER_URL=http://localhost:3010
NEXT_PUBLIC_WEB_URL=http://localhost:3005

# --- Local development -------------------------------------------------------
# Write content fixtures directly to content/ instead of opening GitHub PRs.
CONTENT_LOCAL_WRITE=true

# --- GitHub workflow (optional — production PR flow) -------------------------
# GITHUB_OWNER=status-im
# GITHUB_REPO=status-web
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_INSTALLATION_ID=
# GITHUB_PR_BASE_BRANCH=develop
