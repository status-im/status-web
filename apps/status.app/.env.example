# Status.app environment variables.
# Copy to `.env.local` and fill in the values you need.
# On Vercel: `vercel env pull .env.local` works too.

# ────────────────────────────────────────────────────────────────────────────
# Build-time (required for `next build` — SSG/ISR fetches Ghost/GitHub/Greenhouse)
# ────────────────────────────────────────────────────────────────────────────

# Ghost Content API — blog posts (homepage, /blog/*, /sitemap.xml, RSS feeds)
NEXT_PUBLIC_GHOST_API_URL=https://demo.ghost.io
NEXT_PUBLIC_GHOST_API_KEY=

# Infura — ENS resolution on `/api/ens` (server) + sharing pages (client)
INFURA_API_KEY=
NEXT_PUBLIC_INFURA_API_KEY=

# Greenhouse — jobs listing and job application proxy
GREENHOUSE_API_KEY=
GREENHOUSE_STATUS_BOARD_ID=
GREENHOUSE_LOGOS_BOARD_ID=

# GitHub — latest status-app release for nav promo bar, /apps page, and /api/download/*
GITHUB_TOKEN=

# Hasura — public insights GraphQL (client-side)
NEXT_PUBLIC_HASURA_API_URL=

# ────────────────────────────────────────────────────────────────────────────
# Runtime-only (required for `next start` — admin and live API routes)
# Set in the container/orchestrator at run time, not baked into the image.
# ────────────────────────────────────────────────────────────────────────────

# Canonical site origin (e.g. https://status.app). REQUIRED on self-hosted
# deployments: prevents host-header injection via `X-Forwarded-Host` from
# influencing OAuth redirect URIs and server-side fetches.
SITE_URL=https://status.app

# Postgres — admin /insights, /reporting (any standard Postgres URL)
POSTGRES_URL=postgresql://username:password@localhost:5432/database_name

# Keycloak — admin auth (external service)
KEYCLOAK_API_URL=
KEYCLOAK_REALM=
KEYCLOAK_ISSUER=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# BambooHR — contributor list for admin reporting
BAMBOOHR_API_KEY=

# ────────────────────────────────────────────────────────────────────────────
# Optional
# ────────────────────────────────────────────────────────────────────────────

# Umami — server-side event tracking for /api/download/* (replaces @vercel/analytics).
# Without this, downloads still work; they just won't be counted server-side.
UMAMI_WEBSITE_ID=
UMAMI_API_URL=https://umami.bi.status.im/api/send

# Dev server port (default 3001 via package.json dev script)
PORT=3001
