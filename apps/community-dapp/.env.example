# Community dApp environment variables.
# Copy to `.env` and fill in the values, then export them before running dev/build:
#   set -a && source .env && set +a
#
# For local Anvil development, deploy contracts first (see README), then set the
# contract addresses from the forge script output.

# Target environment: development (default) | preview | production
ENV=development

# Infura API key — required for all environments.
# Used by RequestClient (Waku/Status network) and Optimism RPC in preview/production.
INFURA_API_KEY=

# --- Local development only (Anvil / chain ID 31337) ---
# Map forge output labels to these variables (see README for details):
#   MiniMeToken            → TOKEN_CONTRACT
#   Directory              → DIRECTORY_CONTRACT
#   VotingContract         → VOTING_CONTRACT
#   FeaturedVotingContract → FEATURED_VOTING_CONTRACT
#   Multicall2 (in logs)   → MULTICALL_CONTRACT
VOTING_CONTRACT=
DIRECTORY_CONTRACT=
TOKEN_CONTRACT=
MULTICALL_CONTRACT=
FEATURED_VOTING_CONTRACT=
