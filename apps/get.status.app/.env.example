# Copy to .env.local and fill in values:
#   cp .env.example .env.local
#
# Or pull from Vercel (from apps/get.status.app):
#   vercel env pull .env.local

# Optional — required for `pnpm sync:cloudinary` (same Cloudinary account as status.app).
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional — Vercel deployment context (set automatically on Vercel).
# NEXT_PUBLIC_VERCEL_ENV=development
# NEXT_PUBLIC_VERCEL_URL=
# VERCEL=
# VERCEL_ENV=

# Dev server port (default 3005 via package.json dev script).
# PORT=3005
