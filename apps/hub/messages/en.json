  "pre_deposits": {
    "title": {
      "translation": "Pre-Deposit Vaults",
      "notes": "pre_deposits::title"
    },
    "total_value_locked": {
      "translation": "Total Value Locked",
      "notes": "pre_deposits::total_value_locked"
    },
    "tvl_tooltip": {
      "translation": "Sum of token value locked across all vaults",
      "notes": "pre_deposits::tvl_tooltip"
    },
    "dragon_key_alt": {
      "translation": "Dragon with key",
      "notes": "pre_deposits::dragon_key_alt"
    },
    "faq": {
      "translation": "FAQ",
      "notes": "pre_deposits::faq"
    },
    "faq_items": {
      "receiver_address_change": {
        "title": {
          "translation": "Can I change the address where I receive my withdrawal?",
          "notes": "pre_deposits::faq_items::receiver_address_change::title"
        },
        "content": {
          "translation": "Yes, you can change the receiver address during the Unlock step. If you don't change it, assets will be sent to your original depositor address on Linea.",
          "notes": "pre_deposits::faq_items::receiver_address_change::content"
        }
      },
      "unlock_time_length": {
        "title": {
          "translation": "How long does the unlock take?",
          "notes": "pre_deposits::faq_items::unlock_time_length::title"
        },
        "content": {
          "translation": "For ETH and SNT vaults (deposited on Ethereum), it takes approximately 20 minutes for assets to arrive on Linea. For LINEA vaults, the process is faster since assets are already on Linea.",
          "notes": "pre_deposits::faq_items::unlock_time_length::content"
        }
      },
      "rewards_claiming": {
        "title": {
          "translation": "What about my rewards?",
          "notes": "pre_deposits::faq_items::rewards_claiming::title"
        },
        "content": {
          "translation": "Rewards (SNT + LINEA) and accrued yield (ETH, GUSD) are distributed through a separate process from this withdrawal flow. They will be airdropped directly to your wallet on Linea Mainnet — no action required to receive them, as long as your wallet is accessible at the same address on Linea Mainnet.",
          "notes": "pre_deposits::faq_items::rewards_claiming::content"
        }
      },
      "gusd_claiming": {
        "title": {
          "translation": "What about GUSD?",
          "notes": "pre_deposits::faq_items::gusd_claiming::title"
        },
        "content": {
          "translation": "The withdrawal process for GUSD differs from the other vaults, and details will be announced separately soon.",
          "notes": "pre_deposits::faq_items::gusd_claiming::content"
        }
      },
      "linea_vault": {
        "title": {
          "translation": "When will LINEA vault withdrawals be available?",
