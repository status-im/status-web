# Forge deployment environment variables.
# Copy to `.env` in this directory — Foundry loads it automatically when running
# forge from packages/community-contracts.

# Deployer wallet — use one of:
#   ETH_FROM   broadcaster address (optional; often set via --private-key on CLI)
#   MNEMONIC   derive deployer from mnemonic at index 0 (defaults to Anvil test mnemonic)
ETH_FROM=
MNEMONIC=

# RPC and Etherscan API keys (for testnet/mainnet deploys; see foundry.toml)
API_KEY_ALCHEMY=
API_KEY_ETHERSCAN=
API_KEY_INFURA=
API_KEY_OPTIMISM=
API_KEY_OPTIMISTIC_ETHERSCAN=

FOUNDRY_PROFILE=default
